# ============================================
# Base de datos
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=portafolio_javier_urbina
ALLOW_EXIT_ON_IDLE=true

# ============================================
# Cloudinary (subida de imágenes)
# ============================================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ============================================
# JWT
# ============================================
JWT_SECRET=tu_secret_super_seguro
JWT_EXPIRES_IN=24h

# ============================================
# Entorno
# ============================================
# NODE_ENV se define automáticamente según el script
# development: pnpm dev  |  production: pnpm start

# Puerto del servidor (default: 3000)
PORT=3001

# Orígenes permitidos por CORS (separados por comas si son varios)
# Desarrollo: *
# Producción: https://tudominio.com
CORS_ORIGIN=*

# ============================================
# Producción — se pasan como secrets en Fly.io
# ============================================
# Al desplegar en Fly.io, configurar con:
#   fly secrets set \
#     DB_HOST=db.tuproyecto.supabase.co \
#     DB_PORT=5432 \
#     DB_USER=postgres \
#     DB_PASSWORD=tu_password \
#     DB_DATABASE=portafolio_javier_urbina \
#     JWT_SECRET=tu_secret_produccion \
#     CORS_ORIGIN=https://tudominio.vercel.app \
#     CLOUDINARY_CLOUD_NAME=tu_cloud \
#     CLOUDINARY_API_KEY=tu_key \
#     CLOUDINARY_API_SECRET=tu_secret
#
# Para seed de producción:
#   fly secrets set ADMIN_EMAIL=admin@tudominio.com ADMIN_PASSWORD=contraseña_segura
# Luego en la VM:
#   node scripts/seed-prod.js
